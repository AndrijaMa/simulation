# generated telemetry output (keep the folder, not the data)
telemetry/*.ndjson
# persisted runtime settings (may contain the SASL password)
telemetry/*.json

# python
__pycache__/
*.pyc
.venv/
venv/

# os / editor
.DS_Store
*.swp

# kafka TLS material (keep the folder + README, not the secrets)
certs/*.pem
certs/*.key
certs/*.crt
certs/*.p12
certs/*.jks

# local secrets (never commit)
.env
